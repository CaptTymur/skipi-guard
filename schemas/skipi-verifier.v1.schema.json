{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skipi-verifier.v1",
  "title": "Skipi Report Verifier Result",
  "type": "object",
  "required": [
    "schema_version",
    "task",
    "status",
    "claimed_rung",
    "verified_rung",
    "mismatches",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": "skipi-verifier.v1"
    },
    "task": {
      "type": "string"
    },
    "status": {
      "enum": ["pass", "fail"]
    },
    "claimed_rung": {
      "type": "string"
    },
    "verified_rung": {
      "type": "string"
    },
    "mismatches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
