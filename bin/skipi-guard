#!/usr/bin/env python3
from __future__ import annotations

import argparse
import fnmatch
import hashlib
import json
import os
import shlex
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Any


VERSION = "0.1.0"
SCHEMA_VERSION = "skipi-guard.v1"
ROOT = Path(__file__).resolve().parents[1]
CONFIG_DIR = ROOT / "configs" / "homes"
HOOK_TEMPLATE_PATH = ROOT / "templates" / "git-hooks" / "pre-push.skipi-guard.sh"
BOOTSTRAP_WORKFLOW_PATH = ".github/workflows/skipi-guard.yml"
BOOTSTRAP_WORKFLOW_TOKEN = "skipi-guard-workflow-bootstrap"


def run(cmd: list[str], cwd: Path | None = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, cwd=cwd, text=True, capture_output=True)


def load_home_config(home: str) -> dict[str, Any]:
    config_path = CONFIG_DIR / f"{home}.json"
    if not config_path.exists():
        homes = sorted(path.stem for path in CONFIG_DIR.glob("*.json"))
        raise SystemExit(f"unknown home '{home}'. configured homes: {', '.join(homes)}")
    with config_path.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def load_home_config_from_ref(repo: Path, home: str, ref: str) -> dict[str, Any]:
    config_path = f"configs/homes/{home}.json"
    proc = run(["git", "-C", str(repo), "show", f"{ref}:{config_path}"])
    if proc.returncode != 0:
        detail = proc.stderr.strip() or proc.stdout.strip() or f"cannot read {config_path} at {ref}"
        raise ValueError(detail)
    try:
        return json.loads(proc.stdout)
    except json.JSONDecodeError as exc:
        raise ValueError(f"invalid JSON in {config_path} at {ref}: {exc}") from exc


def clean_path(path: str) -> str:
    normalized = path.replace("\\", "/")
    return normalized.removeprefix("./")


def pattern_matches(path: str, pattern: str) -> bool:
    path = clean_path(path)
    pattern = clean_path(pattern)
    if not pattern:
        return False
    if pattern.endswith("/**"):
        prefix = pattern[:-3]
        return path == prefix or path.startswith(prefix + "/")
    if fnmatch.fnmatchcase(path, pattern):
        return True
    if pattern.startswith("**/") and fnmatch.fnmatchcase(path, pattern[3:]):
        return True
    has_glob = any(char in pattern for char in "*?[")
    if not has_glob and "/" not in pattern:
        return path == pattern or path.endswith("/" + pattern)
    return False


def classify_paths(files: list[str], rules: list[dict[str, Any]], kind: str) -> list[dict[str, str]]:
    touches: list[dict[str, str]] = []
    seen: set[tuple[str, str, str]] = set()
    for file_path in files:
        for rule in rules:
            for pattern in rule.get("patterns", []):
                if pattern_matches(file_path, pattern):
                    key = (file_path, kind, rule.get("name", "unnamed"))
                    if key in seen:
                        continue
                    seen.add(key)
                    touches.append(
                        {
                            "path": file_path,
                            "kind": kind,
                            "rule": rule.get("name", "unnamed"),
                            "pattern": pattern,
                        }
                    )
    return touches


def changed_files_between(repo: Path, base: str, head: str) -> tuple[list[str], str, str | None]:
    specs = [(f"{base}...{head}", "triple-dot"), (f"{base}..{head}", "two-dot")]
    errors: list[str] = []
    for spec, mode in specs:
        proc = run(["git", "-C", str(repo), "diff", "--name-only", "--diff-filter=ACDMRTUXB", spec])
        if proc.returncode == 0:
            files = sorted({clean_path(line) for line in proc.stdout.splitlines() if line.strip()})
            return files, mode, None
        errors.append(proc.stderr.strip() or proc.stdout.strip() or f"git diff failed for {spec}")
    return [], "none", " ; ".join(errors)


def short_sha(repo: Path, head: str) -> tuple[str, str | None]:
    proc = run(["git", "-C", str(repo), "rev-parse", "--short", head])
    if proc.returncode != 0:
        return "unknown", proc.stderr.strip() or proc.stdout.strip() or f"cannot resolve {head}"
    return proc.stdout.strip(), None


def is_zero_sha(sha: str) -> bool:
    return len(sha) >= 40 and set(sha) == {"0"}


def git_commit_exists(repo: Path, sha: str) -> bool:
    return run(["git", "-C", str(repo), "cat-file", "-e", f"{sha}^{{commit}}"]).returncode == 0


def resolve_push_base(repo: Path, local_sha: str, remote_sha: str) -> tuple[str | None, str, str | None]:
    """Resolve the diff base for one pushed ref: (base, mode, error).

    Base is the remote sha when it is non-zero and known locally; otherwise
    the merge-base of the pushed sha with origin/main (new branch / unfetched
    remote). No base resolvable -> fail closed (base None + error).
    """
    if remote_sha and not is_zero_sha(remote_sha) and git_commit_exists(repo, remote_sha):
        return remote_sha, "remote-sha", None
    proc = run(["git", "-C", str(repo), "merge-base", local_sha, "origin/main"])
    if proc.returncode == 0 and proc.stdout.strip():
        return proc.stdout.strip(), "merge-base-origin-main", None
    detail = proc.stderr.strip() or proc.stdout.strip() or "cannot resolve merge-base with origin/main"
    return None, "none", detail


def resolve_task(config: dict[str, Any], changed_files: list[str]) -> dict[str, Any]:
    """Resolve the guard task from the diff via declarative task_routing rules.

    Semantics (decision 2026-07-16, management-style): a rule matches only if
    ALL changed files are inside the rule's file set (and, when present, at
    least one file matches require_any_of). A mixed diff falls back to the
    default task. First matching rule wins. Empty diff -> default task.
    """
    default_task = str(config.get("default_task", "plugin-host"))
    if changed_files:
        for rule in config.get("task_routing", []):
            task = str(rule.get("task", ""))
            all_patterns = [str(pattern) for pattern in rule.get("when_all_files_in", [])]
            if not task or not all_patterns:
                continue
            if not all(
                any(pattern_matches(file_path, pattern) for pattern in all_patterns)
                for file_path in changed_files
            ):
                continue
            require_any = [str(pattern) for pattern in rule.get("require_any_of", [])]
            if require_any and not any(
                any(pattern_matches(file_path, pattern) for pattern in require_any)
                for file_path in changed_files
            ):
                continue
            return {"task": task, "rule": str(rule.get("name", task))}
    return {"task": default_task, "rule": None}


def is_release_task(config: dict[str, Any], task: str) -> bool:
    release_tasks = set(config.get("release_tasks", []))
    lowered = task.lower()
    return task in release_tasks or lowered == "release" or lowered.startswith("release-") or lowered.endswith("-release")


def configured_harnesses(config: dict[str, Any], task: str) -> list[dict[str, Any]]:
    commands_by_task = config.get("harness_commands", {})
    harnesses = list(commands_by_task.get(task, []))
    if is_release_task(config, task):
        for inherited_task in ("plugin-host", "provenance", "backend", "landing"):
            harnesses.extend(commands_by_task.get(inherited_task, []))
    return harnesses


def configured_tasks(config: dict[str, Any]) -> set[str]:
    tasks: set[str] = set(str(task) for task in config.get("release_tasks", []))
    tasks.update(str(task) for task in config.get("harness_commands", {}))
    tasks.update(str(task) for task in config.get("allowed_file_patterns", {}))
    return tasks


def unique_harnesses(harnesses: list[dict[str, Any]]) -> list[dict[str, Any]]:
    unique: list[dict[str, Any]] = []
    seen: set[tuple[str, str]] = set()
    for harness in harnesses:
        key = (str(harness.get("name", "")), str(harness.get("command", "")))
        if key in seen:
            continue
        seen.add(key)
        unique.append(harness)
    return unique


def additive_task_checks(config: dict[str, Any], task: str, changed_files: list[str]) -> list[dict[str, Any]]:
    checks: list[dict[str, Any]] = []
    for rule in config.get("additive_task_checks", []):
        additive_task = rule.get("task")
        if not additive_task or additive_task == task:
            continue
        when_tasks = rule.get("when_tasks", [])
        if when_tasks and task not in when_tasks:
            continue
        patterns = rule.get("patterns", [])
        matched_files = sorted(
            {
                file_path
                for file_path in changed_files
                if any(pattern_matches(file_path, pattern) for pattern in patterns)
            }
        )
        if not matched_files:
            continue
        checks.append(
            {
                "name": rule.get("name", additive_task),
                "task": additive_task,
                "matched_files": matched_files,
                "patterns": patterns,
            }
        )
    return checks


def rule_patterns(rules: list[dict[str, Any]]) -> list[str]:
    patterns: list[str] = []
    for rule in rules:
        patterns.extend(str(pattern) for pattern in rule.get("patterns", []))
    return patterns


def effective_allowed_patterns(
    config: dict[str, Any],
    task: str,
    additive_checks: list[dict[str, Any]],
) -> list[str]:
    patterns = list(config.get("allowed_file_patterns", {}).get(task, []))
    if is_release_task(config, task):
        patterns.extend(rule_patterns(config.get("release_sensitive_paths", [])))
        for check in additive_checks:
            patterns.extend(config.get("allowed_file_patterns", {}).get(check["task"], []))
    unique: list[str] = []
    seen: set[str] = set()
    for pattern in patterns:
        if pattern in seen:
            continue
        seen.add(pattern)
        unique.append(pattern)
    return unique


def scope_check_for_task(
    config: dict[str, Any],
    task: str,
    files: list[str],
    allowed_patterns: list[str] | None = None,
) -> dict[str, Any] | None:
    if allowed_patterns is None:
        allowed_patterns = config.get("allowed_file_patterns", {}).get(task, [])
    if not allowed_patterns:
        return None
    violations = [
        file_path for file_path in files if not any(pattern_matches(file_path, pattern) for pattern in allowed_patterns)
    ]
    return {
        "task": task,
        "files": files,
        "allowed_file_patterns": allowed_patterns,
        "scope_violations": violations,
    }


def presence_override_allowed_patterns(config: dict[str, Any], *, include_workflow: bool) -> list[str]:
    patterns = [
        pattern
        for rule in config.get("protected_paths", [])
        if "presence" in str(rule.get("name", "")).lower()
        for pattern in rule.get("patterns", [])
    ]
    for task_patterns in config.get("allowed_file_patterns", {}).values():
        for pattern in task_patterns:
            if "presence" in str(pattern):
                patterns.append(str(pattern))
    if include_workflow:
        patterns.append(".github/workflows/skipi-guard.yml")
    return list(dict.fromkeys(patterns))


def bootstrap_override_allowed_patterns(config: dict[str, Any], token: str) -> list[str] | None:
    if token == "skipi-guard-workflow-bootstrap":
        return [".github/workflows/skipi-guard.yml"]
    home = str(config.get("home", ""))
    if token == f"{home}-presence-contracts-bootstrap":
        return ["presence-manifest.json", "tests/*presence*_harness.mjs", ".github/workflows/skipi-guard.yml"]
    if token == f"{home}-theme-default-bootstrap":
        return ["dist/index.html", "tests/*theme*_harness.mjs", ".github/workflows/skipi-guard.yml"]
    return None


def override_policy_errors(config: dict[str, Any], token: str, changed_files: list[str]) -> list[str]:
    if not token:
        return []
    home = str(config.get("home", ""))
    presence_tokens = {
        f"{home}-presence-modification-approved",
        f"{home}-presence-main-merge-replay",
    }
    if token in presence_tokens:
        allowed_patterns = presence_override_allowed_patterns(config, include_workflow=False)
        disallowed = [
            file_path
            for file_path in changed_files
            if not any(pattern_matches(file_path, pattern) for pattern in allowed_patterns)
        ]
        if disallowed:
            return [
                "presence override requires presence-only changes",
                f"presence override disallowed files: {', '.join(disallowed)}",
            ]
        return []
    allowed_patterns = bootstrap_override_allowed_patterns(config, token)
    if allowed_patterns is None:
        return ["unknown override token"]
    disallowed = [
        file_path
        for file_path in changed_files
        if not any(pattern_matches(file_path, pattern) for pattern in allowed_patterns)
    ]
    if disallowed:
        return [
            f"override token '{token}' is limited to its bootstrap file set",
            f"override disallowed files: {', '.join(disallowed)}",
        ]
    return []


def run_harness_commands(repo: Path, harnesses: list[dict[str, Any]], should_run: bool) -> tuple[list[dict[str, Any]], list[str]]:
    tests: list[dict[str, Any]] = []
    errors: list[str] = []
    for harness in harnesses:
        entry = {
            "name": harness.get("name", "unnamed"),
            "command": harness.get("command", ""),
            "status": "not_run",
            "summary": "configured only; pass --run-harness to execute",
        }
        if should_run:
            proc = subprocess.run(
                harness.get("command", ""),
                cwd=repo,
                shell=True,
                text=True,
                capture_output=True,
            )
            output = "\n".join(part.strip() for part in (proc.stdout, proc.stderr) if part.strip())
            tail = "\n".join(output.splitlines()[-8:]) if output else ""
            entry.update(
                {
                    "status": "pass" if proc.returncode == 0 else "fail",
                    "exit_code": proc.returncode,
                    "summary": tail or f"exit {proc.returncode}",
                }
            )
            if proc.returncode != 0:
                errors.append(f"harness failed: {entry['name']} ({harness.get('command', '')})")
        tests.append(entry)
    return tests, errors


def write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as handle:
        json.dump(payload, handle, indent=2, sort_keys=False)
        handle.write("\n")


def print_summary(result: dict[str, Any]) -> None:
    status = result["status"].upper()
    print(f"Skipi Guard {result['schema_version']}: {status}")
    print(f"home/task: {result['home']} / {result['task']}")
    print(f"repo: {result['repo']}")
    print(f"range: {result['base']} -> {result['head']} ({result.get('comparison', 'unknown')})")
    print(f"sha: {result['sha']}")
    print(f"changed files: {len(result['changed_files'])}")
    if result["changed_files"]:
        for file_path in result["changed_files"][:20]:
            print(f"  - {file_path}")
        if len(result["changed_files"]) > 20:
            print(f"  ... {len(result['changed_files']) - 20} more")
    print(f"protected touches: {len(result['protected_paths_touched'])}")
    print(f"release changes: {'yes' if result['release_changes'] else 'no'}")
    print(f"harness commands: {len(result['tests'])}")
    for test in result["tests"]:
        print(f"  - {test['name']}: {test['status']} :: {test['command']}")
    if result["errors"]:
        print("errors:")
        for error in result["errors"]:
            print(f"  - {error}")


def verify(args: argparse.Namespace) -> int:
    config = load_home_config(args.home)
    auto_task = bool(getattr(args, "auto_task", False))
    if auto_task == bool(args.task):
        raise SystemExit("verify requires exactly one of --task or --auto-task")
    repo = Path(args.repo or config["repo"]).expanduser().resolve()
    override_token = args.override_protected or ""
    errors: list[str] = []

    if not repo.exists():
        errors.append(f"repo does not exist: {repo}")
    elif not (repo / ".git").exists():
        errors.append(f"not a git repo: {repo}")

    sha = "unknown"
    changed_files: list[str] = []
    comparison = "none"
    if not errors:
        sha, sha_error = short_sha(repo, args.head)
        if sha_error:
            errors.append(sha_error)
        changed_files, comparison, diff_error = changed_files_between(repo, args.base, args.head)
        if diff_error:
            errors.append(diff_error)

    task = args.task
    task_rule: str | None = None
    if auto_task:
        routed = resolve_task(config, changed_files)
        task = routed["task"]
        task_rule = routed["rule"]

    auto_bootstrap_override = False
    if (
        not override_token
        and getattr(args, "auto_bootstrap_override", False)
        and changed_files == [BOOTSTRAP_WORKFLOW_PATH]
    ):
        override_token = BOOTSTRAP_WORKFLOW_TOKEN
        auto_bootstrap_override = True
    override_present = bool(override_token)

    task_known = task in configured_tasks(config) or is_release_task(config, task)
    if not task_known:
        errors.append(f"unknown or unconfigured task '{task}'")

    protected_touches = classify_paths(changed_files, config.get("protected_paths", []), "protected")
    release_touches = classify_paths(changed_files, config.get("release_sensitive_paths", []), "release-sensitive")
    protected_paths_touched = protected_touches + release_touches
    release_changes = bool(release_touches)

    if protected_touches and not override_present:
        errors.append("protected path touch requires --override-protected")
    if release_touches and not (override_present or is_release_task(config, task)):
        errors.append("release-sensitive path touch is blocked for this task")

    additive_checks = additive_task_checks(config, task, changed_files)
    effective_tasks = [task]
    for check in additive_checks:
        if check["task"] not in effective_tasks:
            effective_tasks.append(check["task"])

    allowed_patterns = effective_allowed_patterns(config, task, additive_checks)
    scope_violations: list[str] = []
    scope_checks: list[dict[str, Any]] = []
    main_scope_check = scope_check_for_task(config, task, changed_files, allowed_patterns)
    if main_scope_check:
        scope_checks.append(main_scope_check)
    for check in additive_checks:
        additive_scope_check = scope_check_for_task(config, check["task"], check["matched_files"])
        if additive_scope_check:
            scope_checks.append(additive_scope_check)
    for scope_check in scope_checks:
        for violation in scope_check["scope_violations"]:
            if violation not in scope_violations:
                scope_violations.append(violation)
        if scope_check["scope_violations"] and not override_present:
            errors.append(f"changes outside allowed patterns for task '{scope_check['task']}'")
    if override_present:
        errors.extend(override_policy_errors(config, override_token, changed_files))

    harnesses: list[dict[str, Any]] = []
    for effective_task in effective_tasks:
        harnesses.extend(configured_harnesses(config, effective_task))
    if is_release_task(config, task) and not unique_harnesses(harnesses):
        errors.append(f"release task '{task}' requires harness_commands")
    tests, test_errors = run_harness_commands(repo, unique_harnesses(harnesses), args.run_harness)
    errors.extend(test_errors)

    result: dict[str, Any] = {
        "schema_version": SCHEMA_VERSION,
        "home": args.home,
        "task": task,
        "task_source": "auto" if auto_task else "explicit",
        "task_rule": task_rule,
        "effective_tasks": effective_tasks,
        "repo": str(repo),
        "base": args.base,
        "head": args.head,
        "sha": sha,
        "changed_files": changed_files,
        "protected_paths_touched": protected_paths_touched,
        "release_paths_touched": release_touches,
        "release_changes": release_changes,
        "allowed_file_patterns": allowed_patterns,
        "scope_violations": scope_violations,
        "scope_checks": scope_checks,
        "additive_task_checks": additive_checks,
        "tests": tests,
        "override_present": override_present,
        "auto_bootstrap_override": auto_bootstrap_override,
        "comparison": comparison,
        "status": "fail" if errors else "pass",
        "errors": errors,
    }
    push_ref_info = getattr(args, "push_ref_info", None)
    if push_ref_info:
        result["push_ref"] = push_ref_info

    if args.json:
        write_json(Path(args.json), result)
    print_summary(result)
    return 0 if result["status"] == "pass" else 1


def pre_push_ref(args: argparse.Namespace) -> int:
    """Validate one pushed ref from the pre-push stdin line.

    base/head come from the pushed ref (stdin), never from the checkout HEAD
    (SKI-INC-2026-07-16). Harnesses run against the pushed bytes in a
    temporary detached worktree at local_sha. The worktree lives in the
    parent directory of the real repo (variant А, decision 2026-07-16,
    BACKLOG п.40): home harnesses resolve sibling repos relative to the repo
    root (../../skipi-plugins/...), which never exist next to a /tmp path.
    """
    config = load_home_config(args.home)
    # Hooks run with GIT_DIR set relative to the repo root; drop it so git
    # calls against the temporary pushed-bytes worktree resolve correctly.
    for variable in ("GIT_DIR", "GIT_WORK_TREE", "GIT_INDEX_FILE"):
        os.environ.pop(variable, None)
    local_sha = args.local_sha
    if is_zero_sha(local_sha):
        print(f"Skipi Guard pre-push: skip ref deletion {args.remote_ref} (zero local sha)")
        return 0
    repo = Path(args.repo or config["repo"]).expanduser().resolve()
    if not repo.exists() or not (repo / ".git").exists():
        print(f"Skipi Guard pre-push: FAIL not a git repo: {repo}")
        return 1
    if not git_commit_exists(repo, local_sha):
        print(f"Skipi Guard pre-push: FAIL pushed sha {local_sha} not found locally in {repo}")
        return 1
    base, base_mode, base_error = resolve_push_base(repo, local_sha, args.remote_sha)
    if base is None:
        print(f"Skipi Guard pre-push: FAIL cannot resolve base for {args.local_ref}: {base_error}")
        return 1

    json_path = args.json or f"/tmp/skipi-guard-pre-push-{args.home}.json"
    # mkdtemp in the repo parent: unique name (no clash with existing
    # checkouts/worktrees), created as a DIRECT sibling of the real repo so
    # that ../../<sibling> imports in home harnesses resolve exactly as they
    # do from the real checkout. git worktree add accepts the empty dir.
    try:
        worktree = Path(tempfile.mkdtemp(prefix=f".skipi-guard-harness-wt-{args.home}-", dir=repo.parent))
    except OSError as exc:
        print(f"Skipi Guard pre-push: FAIL cannot create harness worktree beside {repo}: {exc}")
        return 1
    worktree_added = False
    try:
        proc = run(["git", "-C", str(repo), "worktree", "add", "--detach", str(worktree), local_sha])
        if proc.returncode != 0:
            detail = proc.stderr.strip() or proc.stdout.strip() or "git worktree add failed"
            print(f"Skipi Guard pre-push: FAIL cannot stage pushed bytes for {args.local_ref}: {detail}")
            return 1
        worktree_added = True
        verify_args = argparse.Namespace(
            home=args.home,
            task=None,
            auto_task=True,
            base=base,
            head=local_sha,
            repo=str(worktree),
            json=json_path,
            run_harness=True,
            override_protected=None,
            auto_bootstrap_override=True,
            push_ref_info={
                "local_ref": args.local_ref,
                "local_sha": local_sha,
                "remote_ref": args.remote_ref,
                "remote_sha": args.remote_sha,
                "base_mode": base_mode,
            },
        )
        return verify(verify_args)
    finally:
        if worktree_added:
            run(["git", "-C", str(repo), "worktree", "remove", "--force", str(worktree)])
        shutil.rmtree(worktree, ignore_errors=True)


def default_guard_bin() -> str:
    return str(ROOT / "bin" / "skipi-guard")


def render_hook(home: str, guard_bin: str | None = None) -> str:
    load_home_config(home)  # fail fast on unknown homes
    template = HOOK_TEMPLATE_PATH.read_text(encoding="utf-8")
    rendered = template.replace("__SKIPI_GUARD_BIN__", guard_bin or default_guard_bin())
    rendered = rendered.replace("__SKIPI_GUARD_HOME__", home)
    if "__SKIPI_GUARD_" in rendered:
        raise SystemExit("hook template contains unrendered placeholders")
    return rendered


def hook_path_for_repo(repo: Path) -> Path:
    proc = run(["git", "-C", str(repo), "rev-parse", "--git-path", "hooks"])
    if proc.returncode != 0:
        raise SystemExit(proc.stderr.strip() or f"cannot resolve hooks dir for {repo}")
    hooks_dir = Path(proc.stdout.strip())
    if not hooks_dir.is_absolute():
        hooks_dir = (repo / hooks_dir).resolve()
    return hooks_dir / "pre-push"


def resolve_hook_repo(args: argparse.Namespace) -> Path:
    config = load_home_config(args.home)
    repo = Path(args.repo or config["repo"]).expanduser().resolve()
    if not repo.exists() or not (repo / ".git").exists():
        raise SystemExit(f"not a git repo: {repo}")
    return repo


def sha256_hex(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def hooks_render(args: argparse.Namespace) -> int:
    sys.stdout.write(render_hook(args.home, args.guard_bin))
    return 0


def hooks_install(args: argparse.Namespace) -> int:
    repo = resolve_hook_repo(args)
    rendered = render_hook(args.home, args.guard_bin)
    hook_path = hook_path_for_repo(repo)
    hook_path.parent.mkdir(parents=True, exist_ok=True)
    hook_path.write_text(rendered, encoding="utf-8")
    hook_path.chmod(0o755)
    print(f"installed {hook_path} (home={args.home}, sha256={sha256_hex(rendered.encode('utf-8'))})")
    return 0


def hooks_check(args: argparse.Namespace) -> int:
    repo = resolve_hook_repo(args)
    rendered = render_hook(args.home, args.guard_bin).encode("utf-8")
    hook_path = hook_path_for_repo(repo)
    if not hook_path.exists():
        print(f"MISSING {hook_path} (home={args.home}): no deployed pre-push hook")
        return 1
    deployed = hook_path.read_bytes()
    if deployed == rendered:
        print(f"MATCH {hook_path} (home={args.home}, sha256={sha256_hex(deployed)})")
        return 0
    print(
        f"DRIFT {hook_path} (home={args.home}): "
        f"deployed sha256={sha256_hex(deployed)} != render(canon) sha256={sha256_hex(rendered)}"
    )
    return 1


def list_homes() -> int:
    for path in sorted(CONFIG_DIR.glob("*.json")):
        with path.open("r", encoding="utf-8") as handle:
            config = json.load(handle)
        print(f"{path.stem}\t{config.get('repo', '')}")
    return 0


def harness_commands_by_task(config: dict[str, Any]) -> dict[str, dict[str, str]]:
    commands: dict[str, dict[str, str]] = {}
    for task, entries in config.get("harness_commands", {}).items():
        commands[str(task)] = {
            str(entry.get("name", "")): str(entry.get("command", ""))
            for entry in entries
            if entry.get("name")
        }
    return commands


def canonical_json(value: Any) -> str:
    return json.dumps(value, sort_keys=True, separators=(",", ":"))


def missing_additive_checks(old_config: dict[str, Any], new_config: dict[str, Any]) -> list[dict[str, Any]]:
    new_checks = {canonical_json(entry) for entry in new_config.get("additive_task_checks", [])}
    return [
        entry
        for entry in old_config.get("additive_task_checks", [])
        if canonical_json(entry) not in new_checks
    ]


def missing_allowed_patterns(old_config: dict[str, Any], new_config: dict[str, Any]) -> list[dict[str, str]]:
    missing: list[dict[str, str]] = []
    old_patterns = old_config.get("allowed_file_patterns", {})
    new_patterns = new_config.get("allowed_file_patterns", {})
    for task, patterns in sorted(old_patterns.items()):
        new_for_task = set(str(pattern) for pattern in new_patterns.get(task, []))
        for pattern in sorted(str(pattern) for pattern in patterns):
            if pattern not in new_for_task:
                missing.append({"task": str(task), "pattern": pattern})
    return missing


def missing_named_rule_patterns(
    old_config: dict[str, Any],
    new_config: dict[str, Any],
    section: str,
) -> list[dict[str, str]]:
    missing: list[dict[str, str]] = []
    new_rules: dict[str, set[str]] = {}
    for rule in new_config.get(section, []):
        name = str(rule.get("name", "unnamed"))
        new_rules.setdefault(name, set()).update(str(pattern) for pattern in rule.get("patterns", []))
    for rule in old_config.get(section, []):
        name = str(rule.get("name", "unnamed"))
        new_patterns = new_rules.get(name, set())
        for pattern in sorted(str(pattern) for pattern in rule.get("patterns", [])):
            if pattern not in new_patterns:
                missing.append({"rule": name, "pattern": pattern})
    return missing


def assert_config_superset(args: argparse.Namespace) -> int:
    repo = Path(args.repo or ROOT).expanduser().resolve()
    errors: list[str] = []
    missing_harnesses: list[dict[str, str]] = []
    missing_additive: list[dict[str, Any]] = []
    missing_allowed: list[dict[str, str]] = []
    missing_release_sensitive: list[dict[str, str]] = []
    missing_protected: list[dict[str, str]] = []
    old_config: dict[str, Any] = {}
    new_config: dict[str, Any] = {}

    if not repo.exists():
        errors.append(f"repo does not exist: {repo}")
    elif not (repo / ".git").exists():
        errors.append(f"not a git repo: {repo}")

    if not errors:
        try:
            old_config = load_home_config_from_ref(repo, args.home, args.old_ref)
            new_config = load_home_config_from_ref(repo, args.home, args.new_ref)
        except ValueError as exc:
            errors.append(str(exc))

    old_harnesses = harness_commands_by_task(old_config)
    new_harnesses = harness_commands_by_task(new_config)
    if not errors:
        for task, old_entries in sorted(old_harnesses.items()):
            new_entries = new_harnesses.get(task, {})
            for name, command in sorted(old_entries.items()):
                if new_entries.get(name) != command:
                    missing_harnesses.append(
                        {
                            "task": task,
                            "name": name,
                            "command": command,
                        }
                    )
        if missing_harnesses:
            errors.append("new guard config removes harness_commands from the current config")
        missing_additive = missing_additive_checks(old_config, new_config)
        if missing_additive:
            errors.append("new guard config removes additive_task_checks from the current config")
        missing_allowed = missing_allowed_patterns(old_config, new_config)
        if missing_allowed:
            errors.append("new guard config removes allowed_file_patterns from the current config")
        missing_release_sensitive = missing_named_rule_patterns(old_config, new_config, "release_sensitive_paths")
        if missing_release_sensitive:
            errors.append("new guard config removes release_sensitive_paths from the current config")
        missing_protected = missing_named_rule_patterns(old_config, new_config, "protected_paths")
        if missing_protected:
            errors.append("new guard config removes protected_paths from the current config")

    result: dict[str, Any] = {
        "schema_version": SCHEMA_VERSION,
        "home": args.home,
        "repo": str(repo),
        "old_ref": args.old_ref,
        "new_ref": args.new_ref,
        "old_tasks": sorted(old_harnesses),
        "new_tasks": sorted(new_harnesses),
        "missing_harnesses": missing_harnesses,
        "missing_additive_task_checks": missing_additive,
        "missing_allowed_file_patterns": missing_allowed,
        "missing_release_sensitive_paths": missing_release_sensitive,
        "missing_protected_paths": missing_protected,
        "status": "fail" if errors else "pass",
        "errors": errors,
    }
    if args.json:
        write_json(Path(args.json), result)

    print(f"Skipi Guard {SCHEMA_VERSION}: {result['status'].upper()}")
    print(f"home: {args.home}")
    print(f"repo: {repo}")
    print(f"old ref: {args.old_ref}")
    print(f"new ref: {args.new_ref}")
    if missing_harnesses:
        print("missing harnesses:")
        for harness in missing_harnesses:
            print(f"  - {harness['task']} / {harness['name']}: {harness['command']}")
    if missing_additive:
        print("missing additive task checks:")
        for check in missing_additive:
            print(f"  - {canonical_json(check)}")
    if missing_allowed:
        print("missing allowed file patterns:")
        for pattern in missing_allowed:
            print(f"  - {pattern['task']}: {pattern['pattern']}")
    if missing_release_sensitive:
        print("missing release-sensitive paths:")
        for pattern in missing_release_sensitive:
            print(f"  - {pattern['rule']}: {pattern['pattern']}")
    if missing_protected:
        print("missing protected paths:")
        for pattern in missing_protected:
            print(f"  - {pattern['rule']}: {pattern['pattern']}")
    if errors:
        print("errors:")
        for error in errors:
            print(f"  - {error}")
    return 0 if result["status"] == "pass" else 1


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="skipi-guard", description="Stop-line guard for Skipi homes.")
    parser.add_argument("--version", action="store_true", help="print version and exit")
    subparsers = parser.add_subparsers(dest="command")

    verify_parser = subparsers.add_parser("verify", help="verify a home/task diff against stop-line config")
    verify_parser.add_argument("--home", required=True, help="configured Skipi home")
    verify_parser.add_argument("--task", help="task key, for example plugin-host")
    verify_parser.add_argument(
        "--auto-task",
        action="store_true",
        help="resolve the task from the diff via declarative task_routing rules (exactly one of --task/--auto-task)",
    )
    verify_parser.add_argument("--base", default="origin/main", help="base git ref")
    verify_parser.add_argument("--head", default="HEAD", help="head git ref")
    verify_parser.add_argument("--repo", help="override repo path for fixtures or dry-runs")
    verify_parser.add_argument("--json", help="write machine-readable guard result JSON")
    verify_parser.add_argument("--run-harness", action="store_true", help="execute configured harness commands")
    verify_parser.add_argument(
        "--override-protected",
        metavar="TOKEN",
        help="explicit token acknowledging protected-path stop-line override; token is not written to JSON",
    )
    verify_parser.add_argument(
        "--auto-bootstrap-override",
        action="store_true",
        help=f"apply the {BOOTSTRAP_WORKFLOW_TOKEN} token when the diff is exactly {BOOTSTRAP_WORKFLOW_PATH}",
    )
    verify_parser.set_defaults(func=verify)

    pre_push_parser = subparsers.add_parser(
        "pre-push-ref",
        help="validate one pushed ref from a pre-push stdin line (base/head from the pushed ref, not checkout HEAD)",
    )
    pre_push_parser.add_argument("--home", required=True, help="configured Skipi home")
    pre_push_parser.add_argument("--repo", help="repo being pushed; defaults to the configured home repo")
    pre_push_parser.add_argument("--local-ref", required=True, help="local ref from pre-push stdin")
    pre_push_parser.add_argument("--local-sha", required=True, help="local sha from pre-push stdin")
    pre_push_parser.add_argument("--remote-ref", required=True, help="remote ref from pre-push stdin")
    pre_push_parser.add_argument("--remote-sha", required=True, help="remote sha from pre-push stdin")
    pre_push_parser.add_argument(
        "--json",
        help="write machine-readable guard result JSON (default /tmp/skipi-guard-pre-push-<home>.json)",
    )
    pre_push_parser.set_defaults(func=pre_push_ref)

    hooks_parser = subparsers.add_parser("hooks", help="git-tracked pre-push hook canon: render, install, drift check")
    hooks_subparsers = hooks_parser.add_subparsers(dest="hooks_command", required=True)

    hooks_render_parser = hooks_subparsers.add_parser("render", help="print the canonical pre-push hook for a home")
    hooks_render_parser.add_argument("--home", required=True, help="configured Skipi home")
    hooks_render_parser.add_argument("--guard-bin", help="skipi-guard binary path baked into the hook (default: this checkout)")
    hooks_render_parser.set_defaults(func=hooks_render)

    hooks_install_parser = hooks_subparsers.add_parser(
        "install", help="install the canonical pre-push hook into a home checkout"
    )
    hooks_install_parser.add_argument("--home", required=True, help="configured Skipi home")
    hooks_install_parser.add_argument("--repo", help="target checkout; defaults to the configured home repo")
    hooks_install_parser.add_argument("--guard-bin", help="skipi-guard binary path baked into the hook (default: this checkout)")
    hooks_install_parser.set_defaults(func=hooks_install)

    hooks_check_parser = hooks_subparsers.add_parser(
        "check", help="fail (exit 1) when the deployed pre-push hook drifts from render(canon)"
    )
    hooks_check_parser.add_argument("--home", required=True, help="configured Skipi home")
    hooks_check_parser.add_argument("--repo", help="target checkout; defaults to the configured home repo")
    hooks_check_parser.add_argument("--guard-bin", help="skipi-guard binary path baked into the hook (default: this checkout)")
    hooks_check_parser.set_defaults(func=hooks_check)

    homes_parser = subparsers.add_parser("list-homes", help="list configured homes")
    homes_parser.set_defaults(func=lambda _args: list_homes())

    superset_parser = subparsers.add_parser(
        "assert-config-superset",
        help="fail if a proposed guard config removes harness commands from the current config",
    )
    superset_parser.add_argument("--home", required=True, help="configured Skipi home")
    superset_parser.add_argument("--old-ref", required=True, help="current accepted guard ref")
    superset_parser.add_argument("--new-ref", required=True, help="proposed guard ref")
    superset_parser.add_argument("--repo", help="guard repo path; defaults to this repository")
    superset_parser.add_argument("--json", help="write machine-readable result JSON")
    superset_parser.set_defaults(func=assert_config_superset)

    version_parser = subparsers.add_parser("version", help="print version")
    version_parser.set_defaults(func=lambda _args: print(f"skipi-guard {VERSION}") or 0)
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.version:
        print(f"skipi-guard {VERSION}")
        return 0
    if not hasattr(args, "func"):
        parser.print_help()
        return 0
    return int(args.func(args))


if __name__ == "__main__":
    sys.exit(main())
