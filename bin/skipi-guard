#!/usr/bin/env python3
from __future__ import annotations

import argparse
import fnmatch
import json
import os
import shlex
import subprocess
import sys
from pathlib import Path
from typing import Any


VERSION = "0.1.0"
SCHEMA_VERSION = "skipi-guard.v1"
ROOT = Path(__file__).resolve().parents[1]
CONFIG_DIR = ROOT / "configs" / "homes"


def run(cmd: list[str], cwd: Path | None = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, cwd=cwd, text=True, capture_output=True)


def load_home_config(home: str) -> dict[str, Any]:
    config_path = CONFIG_DIR / f"{home}.json"
    if not config_path.exists():
        homes = sorted(path.stem for path in CONFIG_DIR.glob("*.json"))
        raise SystemExit(f"unknown home '{home}'. configured homes: {', '.join(homes)}")
    with config_path.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def load_home_config_from_ref(repo: Path, home: str, ref: str) -> dict[str, Any]:
    config_path = f"configs/homes/{home}.json"
    proc = run(["git", "-C", str(repo), "show", f"{ref}:{config_path}"])
    if proc.returncode != 0:
        detail = proc.stderr.strip() or proc.stdout.strip() or f"cannot read {config_path} at {ref}"
        raise ValueError(detail)
    try:
        return json.loads(proc.stdout)
    except json.JSONDecodeError as exc:
        raise ValueError(f"invalid JSON in {config_path} at {ref}: {exc}") from exc


def clean_path(path: str) -> str:
    return path.replace("\\", "/").lstrip("./")


def pattern_matches(path: str, pattern: str) -> bool:
    path = clean_path(path)
    pattern = clean_path(pattern)
    if not pattern:
        return False
    if pattern.endswith("/**"):
        prefix = pattern[:-3]
        return path == prefix or path.startswith(prefix + "/")
    if fnmatch.fnmatchcase(path, pattern):
        return True
    if pattern.startswith("**/") and fnmatch.fnmatchcase(path, pattern[3:]):
        return True
    has_glob = any(char in pattern for char in "*?[")
    if not has_glob and "/" not in pattern:
        return path == pattern or path.endswith("/" + pattern) or path.startswith(pattern + "/")
    return False


def classify_paths(files: list[str], rules: list[dict[str, Any]], kind: str) -> list[dict[str, str]]:
    touches: list[dict[str, str]] = []
    seen: set[tuple[str, str, str]] = set()
    for file_path in files:
        for rule in rules:
            for pattern in rule.get("patterns", []):
                if pattern_matches(file_path, pattern):
                    key = (file_path, kind, rule.get("name", "unnamed"))
                    if key in seen:
                        continue
                    seen.add(key)
                    touches.append(
                        {
                            "path": file_path,
                            "kind": kind,
                            "rule": rule.get("name", "unnamed"),
                            "pattern": pattern,
                        }
                    )
    return touches


def changed_files_between(repo: Path, base: str, head: str) -> tuple[list[str], str, str | None]:
    specs = [(f"{base}...{head}", "triple-dot"), (f"{base}..{head}", "two-dot")]
    errors: list[str] = []
    for spec, mode in specs:
        proc = run(["git", "-C", str(repo), "diff", "--name-only", "--diff-filter=ACDMRTUXB", spec])
        if proc.returncode == 0:
            files = sorted({clean_path(line) for line in proc.stdout.splitlines() if line.strip()})
            return files, mode, None
        errors.append(proc.stderr.strip() or proc.stdout.strip() or f"git diff failed for {spec}")
    return [], "none", " ; ".join(errors)


def short_sha(repo: Path, head: str) -> tuple[str, str | None]:
    proc = run(["git", "-C", str(repo), "rev-parse", "--short", head])
    if proc.returncode != 0:
        return "unknown", proc.stderr.strip() or proc.stdout.strip() or f"cannot resolve {head}"
    return proc.stdout.strip(), None


def is_release_task(config: dict[str, Any], task: str) -> bool:
    release_tasks = set(config.get("release_tasks", []))
    lowered = task.lower()
    return task in release_tasks or lowered == "release" or lowered.startswith("release-") or lowered.endswith("-release")


def configured_harnesses(config: dict[str, Any], task: str) -> list[dict[str, Any]]:
    commands_by_task = config.get("harness_commands", {})
    return list(commands_by_task.get(task, []))


def unique_harnesses(harnesses: list[dict[str, Any]]) -> list[dict[str, Any]]:
    unique: list[dict[str, Any]] = []
    seen: set[tuple[str, str]] = set()
    for harness in harnesses:
        key = (str(harness.get("name", "")), str(harness.get("command", "")))
        if key in seen:
            continue
        seen.add(key)
        unique.append(harness)
    return unique


def additive_task_checks(config: dict[str, Any], task: str, changed_files: list[str]) -> list[dict[str, Any]]:
    checks: list[dict[str, Any]] = []
    for rule in config.get("additive_task_checks", []):
        additive_task = rule.get("task")
        if not additive_task or additive_task == task:
            continue
        when_tasks = rule.get("when_tasks", [])
        if when_tasks and task not in when_tasks:
            continue
        patterns = rule.get("patterns", [])
        matched_files = sorted(
            {
                file_path
                for file_path in changed_files
                if any(pattern_matches(file_path, pattern) for pattern in patterns)
            }
        )
        if not matched_files:
            continue
        checks.append(
            {
                "name": rule.get("name", additive_task),
                "task": additive_task,
                "matched_files": matched_files,
                "patterns": patterns,
            }
        )
    return checks


def scope_check_for_task(
    config: dict[str, Any],
    task: str,
    files: list[str],
) -> dict[str, Any] | None:
    allowed_patterns = config.get("allowed_file_patterns", {}).get(task, [])
    if not allowed_patterns:
        return None
    violations = [
        file_path for file_path in files if not any(pattern_matches(file_path, pattern) for pattern in allowed_patterns)
    ]
    return {
        "task": task,
        "files": files,
        "allowed_file_patterns": allowed_patterns,
        "scope_violations": violations,
    }


def run_harness_commands(repo: Path, harnesses: list[dict[str, Any]], should_run: bool) -> tuple[list[dict[str, Any]], list[str]]:
    tests: list[dict[str, Any]] = []
    errors: list[str] = []
    for harness in harnesses:
        entry = {
            "name": harness.get("name", "unnamed"),
            "command": harness.get("command", ""),
            "status": "not_run",
            "summary": "configured only; pass --run-harness to execute",
        }
        if should_run:
            proc = subprocess.run(
                harness.get("command", ""),
                cwd=repo,
                shell=True,
                text=True,
                capture_output=True,
            )
            output = "\n".join(part.strip() for part in (proc.stdout, proc.stderr) if part.strip())
            tail = "\n".join(output.splitlines()[-8:]) if output else ""
            entry.update(
                {
                    "status": "pass" if proc.returncode == 0 else "fail",
                    "exit_code": proc.returncode,
                    "summary": tail or f"exit {proc.returncode}",
                }
            )
            if proc.returncode != 0:
                errors.append(f"harness failed: {entry['name']} ({harness.get('command', '')})")
        tests.append(entry)
    return tests, errors


def write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as handle:
        json.dump(payload, handle, indent=2, sort_keys=False)
        handle.write("\n")


def print_summary(result: dict[str, Any]) -> None:
    status = result["status"].upper()
    print(f"Skipi Guard {result['schema_version']}: {status}")
    print(f"home/task: {result['home']} / {result['task']}")
    print(f"repo: {result['repo']}")
    print(f"range: {result['base']} -> {result['head']} ({result.get('comparison', 'unknown')})")
    print(f"sha: {result['sha']}")
    print(f"changed files: {len(result['changed_files'])}")
    if result["changed_files"]:
        for file_path in result["changed_files"][:20]:
            print(f"  - {file_path}")
        if len(result["changed_files"]) > 20:
            print(f"  ... {len(result['changed_files']) - 20} more")
    print(f"protected touches: {len(result['protected_paths_touched'])}")
    print(f"release changes: {'yes' if result['release_changes'] else 'no'}")
    print(f"harness commands: {len(result['tests'])}")
    for test in result["tests"]:
        print(f"  - {test['name']}: {test['status']} :: {test['command']}")
    if result["errors"]:
        print("errors:")
        for error in result["errors"]:
            print(f"  - {error}")


def verify(args: argparse.Namespace) -> int:
    config = load_home_config(args.home)
    repo = Path(args.repo or config["repo"]).expanduser().resolve()
    override_token = args.override_protected or os.environ.get("SKIPI_GUARD_OVERRIDE_TOKEN", "")
    override_present = bool(override_token)
    errors: list[str] = []

    if not repo.exists():
        errors.append(f"repo does not exist: {repo}")
    elif not (repo / ".git").exists():
        errors.append(f"not a git repo: {repo}")

    sha = "unknown"
    changed_files: list[str] = []
    comparison = "none"
    if not errors:
        sha, sha_error = short_sha(repo, args.head)
        if sha_error:
            errors.append(sha_error)
        changed_files, comparison, diff_error = changed_files_between(repo, args.base, args.head)
        if diff_error:
            errors.append(diff_error)

    protected_touches = classify_paths(changed_files, config.get("protected_paths", []), "protected")
    release_touches = classify_paths(changed_files, config.get("release_sensitive_paths", []), "release-sensitive")
    protected_paths_touched = protected_touches + release_touches
    release_changes = bool(release_touches)

    if protected_touches and not override_present:
        errors.append("protected path touch requires --override-protected or SKIPI_GUARD_OVERRIDE_TOKEN")
    if release_touches and not (override_present or is_release_task(config, args.task)):
        errors.append("release-sensitive path touch is blocked for this task")

    additive_checks = additive_task_checks(config, args.task, changed_files)
    effective_tasks = [args.task]
    for check in additive_checks:
        if check["task"] not in effective_tasks:
            effective_tasks.append(check["task"])

    allowed_patterns = config.get("allowed_file_patterns", {}).get(args.task, [])
    scope_violations: list[str] = []
    scope_checks: list[dict[str, Any]] = []
    main_scope_check = scope_check_for_task(config, args.task, changed_files)
    if main_scope_check:
        scope_checks.append(main_scope_check)
    for check in additive_checks:
        additive_scope_check = scope_check_for_task(config, check["task"], check["matched_files"])
        if additive_scope_check:
            scope_checks.append(additive_scope_check)
    for scope_check in scope_checks:
        scope_violations.extend(scope_check["scope_violations"])
        if scope_check["scope_violations"] and not override_present:
            errors.append(f"changes outside allowed patterns for task '{scope_check['task']}'")

    harnesses: list[dict[str, Any]] = []
    for task in effective_tasks:
        harnesses.extend(configured_harnesses(config, task))
    tests, test_errors = run_harness_commands(repo, unique_harnesses(harnesses), args.run_harness)
    errors.extend(test_errors)

    result: dict[str, Any] = {
        "schema_version": SCHEMA_VERSION,
        "home": args.home,
        "task": args.task,
        "effective_tasks": effective_tasks,
        "repo": str(repo),
        "base": args.base,
        "head": args.head,
        "sha": sha,
        "changed_files": changed_files,
        "protected_paths_touched": protected_paths_touched,
        "release_paths_touched": release_touches,
        "release_changes": release_changes,
        "allowed_file_patterns": allowed_patterns,
        "scope_violations": scope_violations,
        "scope_checks": scope_checks,
        "additive_task_checks": additive_checks,
        "tests": tests,
        "override_present": override_present,
        "comparison": comparison,
        "status": "fail" if errors else "pass",
        "errors": errors,
    }

    if args.json:
        write_json(Path(args.json), result)
    print_summary(result)
    return 0 if result["status"] == "pass" else 1


def list_homes() -> int:
    for path in sorted(CONFIG_DIR.glob("*.json")):
        with path.open("r", encoding="utf-8") as handle:
            config = json.load(handle)
        print(f"{path.stem}\t{config.get('repo', '')}")
    return 0


def harness_commands_by_task(config: dict[str, Any]) -> dict[str, dict[str, str]]:
    commands: dict[str, dict[str, str]] = {}
    for task, entries in config.get("harness_commands", {}).items():
        commands[str(task)] = {
            str(entry.get("name", "")): str(entry.get("command", ""))
            for entry in entries
            if entry.get("name")
        }
    return commands


def assert_config_superset(args: argparse.Namespace) -> int:
    repo = Path(args.repo or ROOT).expanduser().resolve()
    errors: list[str] = []
    missing_harnesses: list[dict[str, str]] = []
    old_config: dict[str, Any] = {}
    new_config: dict[str, Any] = {}

    if not repo.exists():
        errors.append(f"repo does not exist: {repo}")
    elif not (repo / ".git").exists():
        errors.append(f"not a git repo: {repo}")

    if not errors:
        try:
            old_config = load_home_config_from_ref(repo, args.home, args.old_ref)
            new_config = load_home_config_from_ref(repo, args.home, args.new_ref)
        except ValueError as exc:
            errors.append(str(exc))

    old_harnesses = harness_commands_by_task(old_config)
    new_harnesses = harness_commands_by_task(new_config)
    if not errors:
        for task, old_entries in sorted(old_harnesses.items()):
            new_entries = new_harnesses.get(task, {})
            for name, command in sorted(old_entries.items()):
                if new_entries.get(name) != command:
                    missing_harnesses.append(
                        {
                            "task": task,
                            "name": name,
                            "command": command,
                        }
                    )
        if missing_harnesses:
            errors.append("new guard config removes harness_commands from the current config")

    result: dict[str, Any] = {
        "schema_version": SCHEMA_VERSION,
        "home": args.home,
        "repo": str(repo),
        "old_ref": args.old_ref,
        "new_ref": args.new_ref,
        "old_tasks": sorted(old_harnesses),
        "new_tasks": sorted(new_harnesses),
        "missing_harnesses": missing_harnesses,
        "status": "fail" if errors else "pass",
        "errors": errors,
    }
    if args.json:
        write_json(Path(args.json), result)

    print(f"Skipi Guard {SCHEMA_VERSION}: {result['status'].upper()}")
    print(f"home: {args.home}")
    print(f"repo: {repo}")
    print(f"old ref: {args.old_ref}")
    print(f"new ref: {args.new_ref}")
    if missing_harnesses:
        print("missing harnesses:")
        for harness in missing_harnesses:
            print(f"  - {harness['task']} / {harness['name']}: {harness['command']}")
    if errors:
        print("errors:")
        for error in errors:
            print(f"  - {error}")
    return 0 if result["status"] == "pass" else 1


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="skipi-guard", description="Stop-line guard for Skipi homes.")
    parser.add_argument("--version", action="store_true", help="print version and exit")
    subparsers = parser.add_subparsers(dest="command")

    verify_parser = subparsers.add_parser("verify", help="verify a home/task diff against stop-line config")
    verify_parser.add_argument("--home", required=True, help="configured Skipi home")
    verify_parser.add_argument("--task", required=True, help="task key, for example plugin-host")
    verify_parser.add_argument("--base", default="origin/main", help="base git ref")
    verify_parser.add_argument("--head", default="HEAD", help="head git ref")
    verify_parser.add_argument("--repo", help="override repo path for fixtures or dry-runs")
    verify_parser.add_argument("--json", help="write machine-readable guard result JSON")
    verify_parser.add_argument("--run-harness", action="store_true", help="execute configured harness commands")
    verify_parser.add_argument(
        "--override-protected",
        metavar="TOKEN",
        help="explicit token acknowledging protected-path stop-line override; token is not written to JSON",
    )
    verify_parser.set_defaults(func=verify)

    homes_parser = subparsers.add_parser("list-homes", help="list configured homes")
    homes_parser.set_defaults(func=lambda _args: list_homes())

    superset_parser = subparsers.add_parser(
        "assert-config-superset",
        help="fail if a proposed guard config removes harness commands from the current config",
    )
    superset_parser.add_argument("--home", required=True, help="configured Skipi home")
    superset_parser.add_argument("--old-ref", required=True, help="current accepted guard ref")
    superset_parser.add_argument("--new-ref", required=True, help="proposed guard ref")
    superset_parser.add_argument("--repo", help="guard repo path; defaults to this repository")
    superset_parser.add_argument("--json", help="write machine-readable result JSON")
    superset_parser.set_defaults(func=assert_config_superset)

    version_parser = subparsers.add_parser("version", help="print version")
    version_parser.set_defaults(func=lambda _args: print(f"skipi-guard {VERSION}") or 0)
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.version:
        print(f"skipi-guard {VERSION}")
        return 0
    if not hasattr(args, "func"):
        parser.print_help()
        return 0
    return int(args.func(args))


if __name__ == "__main__":
    sys.exit(main())
